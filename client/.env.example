# Copy this file to .env and fill in values as needed.
#
# VITE_API_URL
#   Leave UNSET for standard local dev + production Nginx deployments.
#   apiConfig.js handles both automatically via runtime hostname detection.
#
#   Set only for non-standard setups:
#     Local → remote staging:  VITE_API_URL=https://staging.yourdomain.com
#     Split-domain prod:        VITE_API_URL=https://api.yourdomain.com
#
# VITE_API_URL=

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
