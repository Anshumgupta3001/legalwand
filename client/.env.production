# Production environment
# VITE_API_URL is empty — apiConfig.js detects non-localhost at runtime
# and uses '' (empty origin), so all /api/... calls are relative.
# Nginx must proxy /api → http://backend:5000 (see nginx.conf).
#
# Set this only if your frontend and backend are on different domains:
# VITE_API_URL=https://api.yourdomain.com

